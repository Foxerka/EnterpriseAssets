<Window x:Class="EnterpriseAssets.View.Pages.PurchaseDocumentsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Документы по закупке" 
        Height="550" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="📄 Документы по закупке" 
                       FontSize="20" FontWeight="SemiBold" Foreground="#2C3E50"/>
            <TextBlock Text="Прикрепите счета, накладные, акты приёмки" 
                       FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Список документов -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Кнопка загрузки -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="📎 Прикрепить документ" 
                            Background="#4A6FA5" Foreground="White"
                            Padding="12,6" BorderThickness="0" Cursor="Hand"
                            Click="BtnAttachDocument_Click" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbDocumentType" Width="200" Padding="8,4">
                        <ComboBoxItem Content="📄 Счёт (Invoice)" Tag="Invoice" IsSelected="True"/>
                        <ComboBoxItem Content="🚚 Накладная (Delivery Note)" Tag="DeliveryNote"/>
                        <ComboBoxItem Content="✅ Акт приёмки (Act)" Tag="Act"/>
                        <ComboBoxItem Content="📋 Другое" Tag="Other"/>
                    </ComboBox>
                </StackPanel>

                <!-- Список -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DocumentsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F9FA" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" 
                                                   FontSize="20" Margin="0,0,10,0"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FileName}" 
                                                       FontWeight="SemiBold" Foreground="#2C3E50"/>
                                            <TextBlock Text="{Binding TypeDisplay}" 
                                                       FontSize="11" Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding UploadedAt}" 
                                                       FontSize="10" Foreground="#95A5A6"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Content="👁️" ToolTip="Открыть"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" Margin="0,0,5,0"
                                                    Click="BtnOpenDocument_Click"
                                                    Tag="{Binding FilePath}"/>
                                            <Button Content="🗑️" ToolTip="Удалить"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" Foreground="#E74C3C"
                                                    Click="BtnDeleteDocument_Click"
                                                    Tag="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Закрыть" Background="#95A5A6" Foreground="White"
                    Padding="20,8" BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>