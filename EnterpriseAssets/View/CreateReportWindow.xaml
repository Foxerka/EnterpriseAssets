<Window x:Class="EnterpriseAssets.View.CreateReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Создание отчета" 
        Height="650" 
        Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" Padding="20" CornerRadius="8" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Создание нового отчета" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="#333333"/>
                <TextBlock Text="Заполните все необходимые поля для создания отчета" 
                          FontSize="13" 
                          Foreground="#666666"
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Основная форма -->
        <Border Grid.Row="1" Background="White" Padding="25" CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Тип отчета -->
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Тип отчета *" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <ComboBox x:Name="CmbReportType" 
                                     Height="35"
                                     FontSize="13"
                                     SelectedIndex="0">
                                <ComboBoxItem Content="Инвентаризация"/>
                                <ComboBoxItem Content="Списание"/>
                                <ComboBoxItem Content="Ремонт"/>
                                <ComboBoxItem Content="Перемещение"/>
                                <ComboBoxItem Content="Финансовый"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Период -->
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Период отчета *" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Дата начала:" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                                    <DatePicker x:Name="DpPeriodStart" 
                                               Height="35"
                                               FontSize="13"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Дата окончания:" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                                    <DatePicker x:Name="DpPeriodEnd" 
                                               Height="35"
                                               FontSize="13"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Способ создания -->
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Способ создания *" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <RadioButton x:Name="RbText" 
                                           Content="Текстовый отчет" 
                                           GroupName="CreationMethod"
                                           IsChecked="True"
                                           FontSize="13"
                                           Margin="0,0,20,0"
                                           Checked="RbText_Checked"/>
                                <RadioButton x:Name="RbFile" 
                                           Content="Прикрепить файл" 
                                           GroupName="CreationMethod"
                                           FontSize="13"
                                           Checked="RbFile_Checked"/>
                            </StackPanel>

                            <!-- Текстовое поле -->
                            <StackPanel x:Name="TextPanel">
                                <TextBlock Text="Содержимое отчета:" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtReportData" 
                                        Height="150"
                                        TextWrapping="Wrap"
                                        AcceptsReturn="True"
                                        VerticalScrollBarVisibility="Auto"
                                        FontSize="13"
                                        Padding="8"/>
                            </StackPanel>

                            <!-- Панель файла -->
                            <StackPanel x:Name="FilePanel" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Выбранный файл:" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
                                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10" Background="#FAFAFA">
                                            <TextBlock x:Name="TxtSelectedFile" 
                                                      Text="Файл не выбран" 
                                                      Foreground="#999999"
                                                      FontSize="13"
                                                      TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Column="1" 
                                           Content="📁 Выбрать файл" 
                                           Click="BtnSelectFile_Click"
                                           Background="#2196F3"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           Width="130"
                                           Height="35"
                                           Margin="10,18,0,0"
                                           Cursor="Hand"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Кнопки управления -->
        <Border Grid.Row="2" Background="White" Padding="20" CornerRadius="8" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" 
                       Click="BtnCancel_Click"
                       Background="#9E9E9E"
                       Foreground="White"
                       FontWeight="Bold"
                       Width="120"
                       Height="40"
                       Margin="0,0,10,0"
                       Cursor="Hand"/>

                <Button Content="✓ Создать отчет" 
                       Click="BtnCreateReport_Click"
                       Background="#4CAF50"
                       Foreground="White"
                       FontWeight="Bold"
                       Width="150"
                       Height="40"
                       Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>