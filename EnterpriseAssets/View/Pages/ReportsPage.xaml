<Page x:Class="EnterpriseAssets.View.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="Отчеты">

    <Page.Resources>
        <!-- Стиль для карточки отчета -->
        <Style x:Key="ReportCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Конвертер для даты -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и статистика -->
        <Border Grid.Row="0" Background="White" Padding="20" Margin="10">
            <StackPanel>
                <TextBlock Text="Отчеты" 
                          FontSize="28" 
                          FontWeight="Bold" 
                          Foreground="#333333"
                          Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">
                    <Border Background="#2196F3" Padding="15,8" CornerRadius="5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Всего отчетов: " Foreground="White" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTotalReports" Text="0" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#4CAF50" Padding="15,8" CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Отображается: " Foreground="White" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtFilteredReports" Text="0" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Панель фильтров -->
            <Border Grid.Column="0" Background="White" Padding="15" Margin="0,0,10,0" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Фильтры" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                    <!-- Фильтр по сотруднику -->
                    <TextBlock Text="Сотрудник:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbUserFilter" 
         SelectionChanged="CmbUserFilter_SelectionChanged"
         Height="30"
         Margin="0,0,0,15"
         IsEditable="True"
         IsTextSearchEnabled="True"
         TextSearch.TextPath="DisplayName"
         StaysOpenOnEdit="True"/>

                    <!-- Фильтр по типу -->
                    <TextBlock Text="Тип отчета:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbReportType" 
                             SelectionChanged="CmbReportType_SelectionChanged"
                             Height="30"
                             Margin="0,0,0,15">
                        <ComboBoxItem Content="Все типы" IsSelected="True"/>
                        <ComboBoxItem Content="Инвентаризация"/>
                        <ComboBoxItem Content="Списание"/>
                        <ComboBoxItem Content="Ремонт"/>
                        <ComboBoxItem Content="Перемещение"/>
                        <ComboBoxItem Content="Финансовый"/>
                    </ComboBox>

                    <!-- Фильтр по периоду -->
                    <TextBlock Text="Период с:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <DatePicker x:Name="DpPeriodStart" 
                               SelectedDateChanged="DpPeriodStart_SelectedDateChanged"
                               Height="30"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Период по:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <DatePicker x:Name="DpPeriodEnd" 
                               SelectedDateChanged="DpPeriodEnd_SelectedDateChanged"
                               Height="30"
                               Margin="0,0,0,15"/>

                    <!-- Кнопка создания отчета -->
                    <Button Content="Создать отчет" 
                           Click="BtnCreateReport_Click"
                           Background="#2196F3"
                           Foreground="White"
                           FontWeight="Bold"
                           Height="40"
                           Margin="0,20,0,0"
                           Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Список отчетов карточками -->
            <Border Grid.Column="1" Background="White" Padding="10" CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ReportsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ReportCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Информация об отчете -->
                                        <StackPanel Grid.Column="0">
                                            <!-- Тип отчета -->
                                            <TextBlock Text="{Binding report_type}" 
                                                      FontSize="18" 
                                                      FontWeight="Bold"
                                                      Foreground="#333333"
                                                      Margin="0,0,0,8"/>

                                            <!-- Период -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Период: " FontWeight="SemiBold" Foreground="#666666"/>
                                                <TextBlock Foreground="#666666">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0:dd.MM.yyyy} - {1:dd.MM.yyyy}">
                                                            <Binding Path="period_start"/>
                                                            <Binding Path="period_end"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Создан кем -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Создан: " FontWeight="SemiBold" Foreground="#666666"/>
                                                <TextBlock Text="{Binding MASTERS.USERS.full_name}" 
                                                          Foreground="#666666"/>
                                            </StackPanel>

                                            <!-- Дата создания -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Дата создания: " FontWeight="SemiBold" Foreground="#666666"/>
                                                <TextBlock Text="{Binding created_at, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" 
                                                          Foreground="#666666"/>
                                            </StackPanel>

                                            <!-- Наличие файла -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Файл: " FontWeight="SemiBold" Foreground="#666666"/>
                                                <TextBlock Foreground="#666666">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Нет"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding file_path}" Value="{x:Null}">
                                                                    <Setter Property="Text" Value="Нет"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Кнопки действий -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <Button Content="👁 Просмотр" 
                                                   Click="BtnViewReport_Click"
                                                   Background="#4CAF50"
                                                   Foreground="White"
                                                   Width="120"
                                                   Height="35"
                                                   Margin="0,0,0,8"
                                                   Cursor="Hand"/>

                                            <Button Content="⬇ Скачать" 
                                                   Click="BtnDownloadReport_Click"
                                                   Background="#2196F3"
                                                   Foreground="White"
                                                   Width="120"
                                                   Height="35"
                                                   Margin="0,0,0,8"
                                                   Cursor="Hand"/>

                                            <Button Content="🗑 Удалить" 
                                                   Click="BtnDeleteReport_Click"
                                                   Background="#F44336"
                                                   Foreground="White"
                                                   Width="120"
                                                   Height="35"
                                                   Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>