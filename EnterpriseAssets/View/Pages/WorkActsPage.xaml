<Page x:Class="EnterpriseAssets.View.Pages.WorkActsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Акты работ" 
      Background="#F5F7FA"
      Loaded="Page_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Акты работ" 
                   FontSize="24" 
                   FontWeight="SemiBold" 
                   Foreground="#2C3E50" 
                   Margin="0,0,0,20"/>

        <!-- Панель инструментов -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <WrapPanel>
                <Button x:Name="BtnNewAct" 
                        Content="➕ Создать акт" 
                        Click="NewAct_Click" 
                        Background="#4A6FA5" 
                        Foreground="White" 
                        Padding="15,8" 
                        Margin="0,0,10,0" 
                        Cursor="Hand"
                        BorderThickness="0"/>

                <Button x:Name="BtnRefresh" 
                        Content="🔄 Обновить" 
                        Click="Refresh_Click" 
                        Background="#95A5A6" 
                        Foreground="White" 
                        Padding="15,8" 
                        Margin="0,0,10,0" 
                        Cursor="Hand"
                        BorderThickness="0"/>

                <!-- Фильтр: Мои / Все -->
                <Border Background="#F8F9FA" BorderBrush="#E1E5EB" BorderThickness="1" CornerRadius="4" Padding="5" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👁️" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#7F8C8D"/>
                        <RadioButton x:Name="RbMyActs" 
                                     Content="Мои акты" 
                                     GroupName="ViewMode" 
                                     Checked="ViewMode_Changed"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center"/>
                        <RadioButton x:Name="RbAllActs" 
                                     Content="Все акты" 
                                     GroupName="ViewMode" 
                                     IsChecked="True"
                                     Checked="ViewMode_Changed"
                                     VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Поиск -->
                <Border Background="#F8F9FA" BorderBrush="#E1E5EB" BorderThickness="1" CornerRadius="4" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Foreground="#7F8C8D" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBox x:Name="SearchBox" 
                                 Width="220" 
                                 BorderThickness="0" 
                                 Background="Transparent" 
                                 TextChanged="SearchBox_TextChanged" 
                                 ToolTip="Поиск по номеру, оборудованию, мастеру"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Счётчик -->
                <Border Background="#E8F5E9" CornerRadius="4" Padding="10,5" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Всего: " Foreground="#2C3E50" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtTotalCount" Text="0" Foreground="#2C3E50" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Border>

        <!-- Информация о правах -->
        <Border Grid.Row="2" Background="#FFF3E0" CornerRadius="6" Padding="10,8" Margin="0,0,0,15"
                Visibility="{Binding AdminInfoVisibility, FallbackValue=Collapsed}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ️" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TxtAccessInfo" 
                           Text="Вы администратор — видите все акты и можете управлять ими" 
                           Foreground="#E65100" 
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Список актов -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="WorkActsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                                CornerRadius="8" 
                                Padding="15" 
                                Margin="0,0,0,10" 
                                Cursor="Hand" 
                                MouseLeftButtonUp="ActCard_Click" 
                                Tag="{Binding Id}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.08"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Иконка статуса -->
                                <Border Grid.Column="0" 
                                        Width="50" 
                                        Height="50" 
                                        CornerRadius="25" 
                                        Background="{Binding StatusColor}" 
                                        Margin="0,0,15,0">
                                    <TextBlock Text="{Binding Icon}" 
                                               FontSize="24" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Основная информация -->
                                <StackPanel Grid.Column="1">
                                    <!-- Номер акта, оборудование и бейдж доступа -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding ActNumber}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="14" 
                                                   Foreground="#2C3E50"/>
                                        <TextBlock Text=" | " Foreground="#BDC3C7"/>
                                        <TextBlock Text="{Binding EquipmentDisplay}" 
                                                   FontSize="12" 
                                                   Foreground="#7F8C8D"/>

                                        <!-- Бейдж "Мой / Чужой" -->
                                        <Border Background="{Binding AccessBadgeColor}" 
                                                CornerRadius="3" 
                                                Padding="6,2" 
                                                Margin="10,0,0,0">
                                            <TextBlock Text="{Binding AccessBadgeText}" 
                                                       FontSize="10" 
                                                       Foreground="White"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Описание работ -->
                                    <TextBlock Text="{Binding Description}" 
                                               FontSize="12" 
                                               Foreground="#5D6D7E" 
                                               Margin="0,5,0,0" 
                                               TextWrapping="Wrap" 
                                               MaxWidth="500"/>

                                    <!-- Метаданные -->
                                    <WrapPanel Margin="0,8,0,0">
                                        <TextBlock Text="📅" FontSize="11" Foreground="#95A5A6"/>
                                        <TextBlock Text="{Binding ActDate, StringFormat=dd.MM.yyyy}" 
                                                   FontSize="11" Foreground="#5D6D7E" Margin="2,0,15,0"/>

                                        <TextBlock Text="👨‍🔧" FontSize="11" Foreground="#95A5A6"/>
                                        <TextBlock Text="{Binding MasterName}" 
                                                   FontSize="11" Foreground="#5D6D7E" Margin="2,0,15,0"/>

                                        <TextBlock Text="📦" FontSize="11" Foreground="#95A5A6"/>
                                        <TextBlock Text="{Binding QuantityText}" 
                                                   FontSize="11" Foreground="#5D6D7E" Margin="2,0,15,0"/>

                                        <TextBlock Text="🧱" FontSize="11" Foreground="#95A5A6"/>
                                        <TextBlock Text="{Binding MaterialsText}" 
                                                   FontSize="11" Foreground="#5D6D7E" Margin="2,0,15,0"/>

                                        <TextBlock Text="✅" FontSize="11" Foreground="#95A5A6"/>
                                        <TextBlock Text="{Binding StatusName}" 
                                                   FontSize="11" 
                                                   Foreground="{Binding StatusTextColor}" 
                                                   Margin="2,0,0,0"/>
                                    </WrapPanel>
                                </StackPanel>

                                <!-- Правая колонка: статус + действия -->
                                <StackPanel Grid.Column="2" 
                                            HorizontalAlignment="Right" 
                                            VerticalAlignment="Center"
                                            MinWidth="160">

                                    <!-- Быстрая смена статуса (только если есть права) -->
                                    <ComboBox x:Name="CmbQuickStatus"
                                              Height="30"
                                              Margin="0,0,0,5"
                                              Tag="{Binding Id}"
                                              SelectionChanged="QuickStatus_Changed"
                                              Visibility="{Binding StatusDropdownVisibility}"
                                              FontSize="11"/>

                                    <!-- Бейдж завершения -->
                                    <Border Background="{Binding CompletionBadgeColor}" 
                                            CornerRadius="4" 
                                            Padding="8,4" 
                                            Margin="0,0,0,5"
                                            HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding CompletionBadgeText}" 
                                                   Foreground="White" 
                                                   FontSize="10" 
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="{Binding CompletionDateText}" 
                                               FontSize="10" 
                                               Foreground="#7F8C8D" 
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>