<Page x:Class="EnterpriseAssets.View.Pages.WorkActsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Акты работ" Background="#F5F7FA"
      Loaded="Page_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Акты работ" FontSize="24" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <!-- Панель инструментов -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <WrapPanel>
                <Button x:Name="BtnNewAct" Content="➕ Создать акт" Click="NewAct_Click" 
                        Background="#4A6FA5" Foreground="White" Padding="15,8" Margin="0,0,10,0" Cursor="Hand"/>
                <Button x:Name="BtnRefresh" Content="🔄 Обновить" Click="Refresh_Click" 
                        Background="#95A5A6" Foreground="White" Padding="15,8" Margin="0,0,10,0" Cursor="Hand"/>

                <Border Background="#F8F9FA" BorderBrush="#E1E5EB" BorderThickness="1" CornerRadius="4" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Foreground="#7F8C8D" Margin="0,0,5,0"/>
                        <TextBox x:Name="SearchBox" Width="200" BorderThickness="0" Background="Transparent" 
                                 TextChanged="SearchBox_TextChanged" ToolTip="Поиск по номеру или комментариям"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Border>

        <!-- Список актов -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="WorkActsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" 
                                Cursor="Hand" MouseLeftButtonUp="ActCard_Click" Tag="{Binding id}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.05"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Иконка -->
                                <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25" 
                                        Background="{Binding StatusColor}" Margin="0,0,15,0">
                                    <TextBlock Text="{Binding Icon}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Информация -->
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding act_number}" FontWeight="SemiBold" FontSize="14" Foreground="#2C3E50"/>
                                        <TextBlock Text=" | " Foreground="#BDC3C7"/>
                                        <TextBlock Text="{Binding equipment_name}" FontSize="12" Foreground="#7F8C8D"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding description}" FontSize="12" Foreground="#5D6D7E" 
                                               Margin="0,5,0,0" TextWrapping="Wrap" MaxWidth="500"/>

                                    <WrapPanel Margin="0,8,0,0">
                                        <TextBlock Text="📅" FontSize="11" Foreground="#95A5A6"/>
                                        <TextBlock Text="{Binding act_date, StringFormat=dd.MM.yyyy}" FontSize="11" Foreground="#5D6D7E" Margin="2,0,15,0"/>

                                        <TextBlock Text="👨‍🔧" FontSize="11" Foreground="#95A5A6"/>
                                        <TextBlock Text="{Binding master_name}" FontSize="11" Foreground="#5D6D7E" Margin="2,0,5,0"/>

                                        <TextBlock Text="✅" FontSize="11" Foreground="#95A5A6"/>
                                        <TextBlock Text="{Binding act_status}" FontSize="11" Foreground="{Binding StatusTextColor}" Margin="2,0,0,0"/>
                                    </WrapPanel>
                                </StackPanel>

                                <!-- Акт завершения -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Border Background="{Binding HasCompletionAct ? '#27AE60' : '#BDC3C7'}" 
                                            CornerRadius="4" Padding="8,4" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding HasCompletionAct ? '✓ Акт завершения' : '⏳ Ожидает'}" 
                                                   Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="{Binding completion_date, StringFormat='Завершен: dd.MM.yyyy'}" 
                                               FontSize="10" Foreground="#7F8C8D" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>