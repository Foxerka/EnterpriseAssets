<Window x:Class="EnterpriseAssets.View.MaintenanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проведение технического обслуживания"
        Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🔹 Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🔧 Проведение ТО" 
                       FontSize="22" 
                       FontWeight="SemiBold" 
                       Foreground="#2C3E50"/>
            <TextBlock x:Name="TxtAssetInfo" 
                       Text="Оборудование" 
                       FontSize="12" 
                       Foreground="#7F8C8D"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 🔹 Форма (с прокруткой) -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,0,15">
            <StackPanel>

                <!-- 📅 Основная информация -->
                <Border Background="White" BorderBrush="#E1E5EB" BorderThickness="1" 
                        CornerRadius="8" Padding="15" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="📅 Основная информация" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,12"/>

                        <TextBlock Text="Дата проведения ТО *" Foreground="#5D6D7E" Margin="0,0,0,5"/>
                        <DatePicker x:Name="DpMaintenanceDate" 
                                    
                                    Padding="8,6" 
                                    BorderBrush="#BDC3C7"
                                    Margin="0,0,0,12"/>

                        <TextBlock Text="Тип обслуживания *" Foreground="#5D6D7E" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CmbMaintenanceType" 
                                  Padding="8,6" 
                                  Margin="0,0,0,12">
                            <ComboBoxItem Content="Плановое" IsSelected="True"/>
                            <ComboBoxItem Content="Внеплановое"/>
                            <ComboBoxItem Content="Капитальное"/>
                            <ComboBoxItem Content="Аварийное"/>
                        </ComboBox>

                        <TextBlock Text="Описание работ" Foreground="#5D6D7E" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtDescription" 
                                 Padding="10,8" 
                                 BorderBrush="#BDC3C7"
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 Height="80" 
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>
                </Border>

                <!-- 🔧 Детали обслуживания -->
                <Border Background="White" BorderBrush="#E1E5EB" BorderThickness="1" 
                        CornerRadius="8" Padding="15" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="🔧 Детали обслуживания" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,12"/>

                        <TextBlock Text="Заменённые детали / расходники" Foreground="#5D6D7E" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtParts" 
                                 Padding="10,8" 
                                 BorderBrush="#BDC3C7"
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 Height="60" 
                                 VerticalContentAlignment="Top"
                                 Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Стоимость (руб.)" Foreground="#5D6D7E" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtCost" 
                                         Padding="10,8" 
                                         BorderBrush="#BDC3C7"
                                         PreviewTextInput="TxtNumber_PreviewTextInput"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Простой (часы)" Foreground="#5D6D7E" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtDowntime" 
                                         Padding="10,8" 
                                         BorderBrush="#BDC3C7"
                                         PreviewTextInput="TxtNumber_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ⏱️ Наработка и планирование -->
                <Border Background="White" BorderBrush="#E1E5EB" BorderThickness="1" 
                        CornerRadius="8" Padding="15" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="⏱️ Наработка и планирование" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Текущая наработка (часы)" Foreground="#5D6D7E" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtCurrentHours" 
                                         Padding="10,8" 
                                         BorderBrush="#BDC3C7"
                                         PreviewTextInput="TxtNumber_PreviewTextInput"
                                         ToolTip="Общая наработка оборудования на данный момент"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Следующее плановое ТО" Foreground="#5D6D7E" Margin="0,0,0,5"/>
                                <DatePicker x:Name="DpNextMaintenance" 
                                            Padding="8,6" 
                                            BorderBrush="#BDC3C7"
                                            ToolTip="Дата следующего планового обслуживания"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#FFF9E6" CornerRadius="4" Padding="10" Margin="0,5,0,0">
                            <StackPanel>
                                <TextBlock Text="💡 Рекомендация" FontSize="11" FontWeight="SemiBold" 
                                           Foreground="#E67E22" Margin="0,0,0,4"/>
                                <TextBlock Text="После проведения ТО рекомендуется обновить дату следующего обслуживания и текущую наработку оборудования." 
                                           FontSize="10" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 📊 Статус после ТО -->
                <Border Background="White" BorderBrush="#E1E5EB" BorderThickness="1" 
                        CornerRadius="8" Padding="15" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="📊 Статус после ТО" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,12"/>
                        <ComboBox x:Name="CmbNewStatus" Padding="8,6">
                            <ComboBoxItem Content="В эксплуатации" IsSelected="True"/>
                            <ComboBoxItem Content="На обслуживании"/>
                            <ComboBoxItem Content="Неисправен"/>
                        </ComboBox>
                        <TextBlock Text="* Статус оборудования после проведённых работ" 
                                   FontSize="10" Foreground="#95A5A6" FontStyle="Italic" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 🔹 Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" 
                    Background="#95A5A6" 
                    Foreground="White"
                    Padding="20,8" 
                    BorderThickness="0" 
                    Cursor="Hand" 
                    Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
            <Button Content="✅ Сохранить" 
                    Background="#27AE60" 
                    Foreground="White"
                    Padding="20,8" 
                    BorderThickness="0" 
                    Cursor="Hand" 
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>