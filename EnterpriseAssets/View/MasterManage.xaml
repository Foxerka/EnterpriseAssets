<Window x:Class="EnterpriseAssets.View.MasterManage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление МОЛ" Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6FA"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="InfoTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#95A5A6"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="0.8*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть: Основная информация -->
        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,10,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="👤 Основная информация" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="Данные сотрудника" FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                    <TextBlock Text="Пользователь *" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbUsers" DisplayMemberPath="full_name" 
                              FontSize="14" Padding="10" Margin="0,0,0,15" 
                              BorderBrush="#E1E5EB" BorderThickness="1"
                              ToolTip="Выберите пользователя с ролью МОЛ"/>
                    <TextBlock Text="💡 Только пользователи с ролью МОЛ" Style="{StaticResource InfoTextStyle}"/>

                    <TextBlock Text="Дата принятия *" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,15,0,5"/>
                    <DatePicker x:Name="DpHireDate" FontSize="14" Padding="10" Margin="0,0,0,15" 
                                BorderBrush="#E1E5EB" BorderThickness="1"
                                ToolTip="Дата принятия на должность"/>

                    <TextBlock Text="Статус" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <CheckBox x:Name="ChkIsAvailable" Content="Доступен для работ" 
                              FontSize="14" Foreground="#2C3E50" Margin="0,0,0,15" IsChecked="True"
                              ToolTip="Определяет, доступен ли сотрудник для назначения задач"/>

                    <TextBlock Text="Уровень квалификации" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbSkillLevel" FontSize="14" Padding="10" Margin="0,0,0,15" 
                              BorderBrush="#E1E5EB" BorderThickness="1"
                              ToolTip="Уровень профессиональных навыков">
                        <ComboBoxItem Content="Низкий" Tag="низкий"/>
                        <ComboBoxItem Content="Средний" Tag="средний" IsSelected="True"/>
                        <ComboBoxItem Content="Высокий" Tag="высокий"/>
                    </ComboBox>
                    <TextBlock Text="💡 Низкий - новичок, Средний - опытный, Высокий - эксперт" Style="{StaticResource InfoTextStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Центральная часть: Специальность и Квалификация -->
        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" Margin="10,0,10,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="🎓 Профессиональные данные" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="Специальность и квалификация" FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                    <!-- Специальность -->
                    <TextBlock Text="Специальность *" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CmbSpecialty" DisplayMemberPath="Speciality" 
                                  FontSize="14" Padding="10" Margin="0,0,5,0" 
                                  BorderBrush="#E1E5EB" BorderThickness="1"
                                  ToolTip="Выберите специальность"/>
                        <Button Grid.Column="1" Content="➕" Width="40" Background="#4A6FA5" Foreground="White" 
                                BorderThickness="0" Cursor="Hand" Click="BtnAddSpecialty_Click" ToolTip="Добавить новую специальность"/>
                    </Grid>

                    <!-- Квалификация -->
                    <TextBlock Text="Квалификация *" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CmbQualification" DisplayMemberPath="Qualification1" 
                                  FontSize="14" Padding="10" Margin="0,0,5,0" 
                                  BorderBrush="#E1E5EB" BorderThickness="1"
                                  ToolTip="Выберите уровень квалификации"/>
                        <Button Grid.Column="1" Content="➕" Width="40" Background="#4A6FA5" Foreground="White" 
                                BorderThickness="0" Cursor="Hand" Click="BtnAddQualification_Click" ToolTip="Добавить новый уровень квалификации"/>
                    </Grid>

                    <Border Background="#E8F0FE" CornerRadius="6" Padding="12" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="💡 Информация" FontSize="11" FontWeight="SemiBold" Foreground="#4A6FA5"/>
                            <TextBlock Text="МОЛ - материально-ответственное лицо, отвечающее за сохранность и учёт вверенных ему активов." 
                                       FontSize="10" Foreground="#5D6D7E" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Правая часть: Статистика и Кнопки -->
        <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="20" Margin="10,0,0,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="📊 Статистика" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="Только для существующих МОЛ" FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Top" x:Name="StatsPanel" Visibility="Collapsed">
                    <Border Background="#E8F0FE" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="18" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Рабочих актов" FontSize="11" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="TxtWorkActs" Text="0" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#E8F8F5" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅" FontSize="18" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Завершено" FontSize="11" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="TxtCompletionActs" Text="0" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#FEF5E7" CornerRadius="6" Padding="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="18" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Оборудование" FontSize="11" Foreground="#7F8C8D"/>
                                <TextBlock x:Name="TxtEquipment" Text="0" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF3CD" CornerRadius="6" Padding="10" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="⚠️ Примечание" FontSize="11" FontWeight="SemiBold" Foreground="#856404"/>
                            <TextBlock Text="При удалении МОЛ необходимо сначала переназначить все связанные активы и акты." 
                                       FontSize="10" Foreground="#856404" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button x:Name="BtnDelete" Content="🗑️" Background="#E74C3C" Foreground="White" 
                            Width="40" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand" Click="BtnDelete_Click" 
                            ToolTip="Удалить МОЛ"/>
                    <Button Content="❌" Background="#95A5A6" Foreground="White" 
                            Width="40" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click" 
                            ToolTip="Отмена"/>
                    <Button Content="💾" Background="#27AE60" Foreground="White" 
                            Width="40" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click" 
                            ToolTip="Сохранить"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>